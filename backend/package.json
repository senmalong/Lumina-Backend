{
  "name": "vesting-vault-backend",
  "version": "1.0.0",
  "description": "Backend for Vesting Vault system with cliff support for top-ups",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "cross-env NODE_ENV=test jest --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --forceExit",
    "test:integration": "cross-env NODE_ENV=test jest test/auth.integration.test.js --forceExit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:parity": "cross-env NODE_ENV=test jest --testPathPattern='sorobanVestingParity.test' --forceExit --verbose",
    "test:all": "npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@aws-sdk/client-secrets-manager": "^3.1037.0",
    "@graphql-tools/schema": "^10.0.33",
